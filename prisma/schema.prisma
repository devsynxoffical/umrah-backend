generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @default("")
  role         String    @default("USER") // USER, VIP, ADMIN
  isActive     Boolean   @default(true)
  joinedAt     DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt
  bookings     Booking[]
}

model Package {
  id           String    @id @default(uuid())
  slug         String    @unique @default("")
  title        String
  imageUrl     String    @default("")
  images       String    @default("") // Comma separated URLs
  season       String    // e.g., Ramadan, Hajj
  period       String    // e.g., First 10 Days
  priceFrom    Float
  durationDays Int
  makkahHotel  String
  madinahHotel String
  highlights   String    @default("") // Comma separated
  status       String    @default("ACTIVE") // ACTIVE, DRAFT, ARCHIVED
  createdAt    DateTime  @default(now())
  bookings     Booking[]
}

model Booking {
  id            String   @id @default(uuid())
  userId        String
  packageId     String
  travelers     Int
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  departureDate DateTime
  fullName      String   @default("")
  email         String   @default("")
  phone         String   @default("")
  passportNumber String  @default("")
  createdAt     DateTime @default(now())
  
  user          User     @relation(fields: [userId], references: [id])
  package       Package  @relation(fields: [packageId], references: [id])
  payments      Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  bookingId     String
  amount        Float
  method        String   // e.g., Credit Card, Bank Transfer
  status        String   @default("COMPLETED") // COMPLETED, PENDING, FAILED
  createdAt     DateTime @default(now())

  booking       Booking  @relation(fields: [bookingId], references: [id])
}

model VisaApplication {
  id             String   @id @default(uuid())
  pilgrimName    String
  nationality    String
  passportNumber String   @unique
  status         String   @default("IN_REVIEW") // IN_REVIEW, APPROVED, ACTION_REQUIRED
  submittedAt    DateTime @default(now())
}

model CmsContent {
  id          String   @id @default(uuid())
  screen      String
  section     String
  contentKey  String
  contentType String   @default("TEXT") // TEXT, RICHTEXT, URL, JSON
  value       String
  isPublished Boolean  @default(true)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([screen, section, contentKey])
  @@index([screen, isPublished])
}
